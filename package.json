{
  "name": "skycast-pro",
  "version": "1.0.0",
  "private": true,
  "description": "SkyCast Pro - a MERN weather forecast platform for college projects, portfolios, and demos.",
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "build": "npm run build:client",
    "build:client": "npm run build --prefix client",
    "build:vite": "npm run build --prefix client",
    "vercel-build": "npm run build:client",
    "preview": "npm run preview --prefix client",
    "preview:client": "npm run preview --prefix client",
    "lint": "npm run lint --prefix client",
    "install:client": "npm ci --prefix client",
    "install:server": "npm ci --prefix server",
    "install:all": "npm install --prefix client && npm install --prefix server",
    "start": "npm run start --prefix server"
  },
  "keywords": [
    "mern",
    "weather",
    "react",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT"
}
